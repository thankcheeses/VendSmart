# VendSmart — Environment Variables
# Copy to .env.local and fill in your values
# All VITE_* vars are exposed to the browser. Keep secrets server-side only.

# ── Supabase (required for production) ─────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── App URL (used by Edge Functions for Stripe redirect) ───────────────────
VITE_APP_URL=https://your-app.vercel.app

# ── Stripe billing (required for paid plans) ───────────────────────────────
# These are set in Supabase Edge Function secrets, NOT in Vercel env vars.
# Run: supabase secrets set STRIPE_SECRET_KEY=sk_live_...
#
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...         # Edge Function secret — never expose to browser
STRIPE_WEBHOOK_SECRET=whsec_...       # From Stripe Dashboard → Webhooks → your endpoint
STRIPE_PRICE_PRO=price_...            # Stripe Price ID for the $49/mo Pro plan
STRIPE_PRICE_ENTERPRISE=price_...     # Stripe Price ID for Enterprise plan
STRIPE_PRODUCT_PRO=prod_...           # Stripe Product ID for Pro (used in webhook handler)
STRIPE_PRODUCT_ENTERPRISE=prod_...    # Stripe Product ID for Enterprise

# ── Supplier integrations (set as Edge Function secrets via Supabase CLI) ──
# Run: supabase secrets set AMAZON_BUSINESS_CLIENT_ID=...
#
# Amazon Business Ordering API
# https://developer-docs.amazon.com/amazon-business/docs/ordering-api
AMAZON_BUSINESS_CLIENT_ID=amzn1.application-oa2-client....
AMAZON_BUSINESS_CLIENT_SECRET=...
AMAZON_BUSINESS_MARKETPLACE_ID=ATVPDKIKX0DER   # US marketplace

# Sysco Food Distribution API
# https://apic-devportal.sysco.com
SYSCO_API_KEY=...
SYSCO_ACCOUNT_NUMBER=...

# Sam's Club Business API (direct, no EDI required)
SAMS_CLUB_API_KEY=...
SAMS_CLUB_MEMBERSHIP_NUMBER=...

# ── Supabase service role (Edge Functions only — NEVER expose to browser) ──
# Set automatically by Supabase when deploying Edge Functions.
# Only needed if running Edge Functions locally with supabase functions serve.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
